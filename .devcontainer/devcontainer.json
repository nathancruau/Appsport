{
  "name": "ApSport",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install -g @expo/ngrok@^4.1.0",
  "postAttachCommand": "bash /workspaces/Appsport/run.sh",
  "forwardPorts": [8081, 19000, 19001, 19002],
  "portsAttributes": {
    "8081": { "label": "Metro Bundler", "onAutoForward": "silent" }
  }
}
